--- ФУНКЦИЯ ПОИСКА БЛИЖАЙШЕГО NPC ---
local function getNearestEnemy()
    local closest = nil
    local dist = _G.FarmRadius
    
    -- Проходим по всем объектам в Workspace
    for _, v in pairs(game.Workspace:GetDescendants()) do
        -- Проверяем наличие гуманоида (NPC) и жизни
        if v:IsA("Humanoid") and v.Parent:FindFirstChild("HumanoidRootPart") then
            local npc = v.Parent
            -- Не выбираем себя и проверяем здоровье
            if npc ~= player.Character and v.Health > 0 then
                local d = (player.Character.HumanoidRootPart.Position - npc.HumanoidRootPart.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = npc
                end
            end
        end
    end
    return closest
end

--- ЦИКЛ ВЫПОЛНЕНИЯ ---
task.spawn(function()
    while true do
        task.wait(0.1)
        if _G.AutoFarmNearest and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local target = getNearestEnemy()
            if target then
                -- Бежим к NPC
                player.Character.Humanoid:MoveTo(target.HumanoidRootPart.Position)
            end
        end
    end
end)
