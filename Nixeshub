--- ЛОГИКА ---

-- 1. Перетаскивание меню
local dragging, dragInput, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = MainFrame.Position
    end
end)
MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

-- 2. Слайдер радиуса
local isSliding = false
SliderBtn.MouseButton1Down:Connect(function() isSliding = true end)
UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then isSliding = false end end)

RunService.RenderStepped:Connect(function()
    if isSliding then
        local pos = math.clamp((mouse.X - SliderBar.AbsolutePosition.X) / SliderBar.AbsoluteSize.X, 0, 1)
        SliderBtn.Position = UDim2.new(pos, -10, -0.5, 0)
        _G.FarmRadius = math.floor(100 + (pos * 900))
        SliderLabel.Text = "Radius: ".._G.FarmRadius.."m"
    end
end)

-- 3. Открытие настроек по правой кнопке мыши
FarmBtn.MouseButton2Click:Connect(function()
    SettingsFrame.Visible = not SettingsFrame.Visible
end)

-- 4. Переключатель функции
FarmBtn.MouseButton1Click:Connect(function()
    _G.AutoFarmNearest = not _G.AutoFarmNearest
    FarmBtn.Text = _G.AutoFarmNearest and "Auto Farm Nearest: ON" or "Auto Farm Nearest: OFF"
    FarmBtn.TextColor3 = _G.AutoFarmNearest and Color3.fromHex("#52fbf6") or Color3.new(1,1,1)
end)

-- 5. ФУНКЦИЯ ПОИСКА БЛИЖАЙШЕГО NPC
local function getNearestEnemy()
    local closest = nil
    local dist = _G.FarmRadius
    
    -- Ищем во всем Workspace (для универсальности)
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v:IsA("Humanoid") and v.Parent:FindFirstChild("HumanoidRootPart") then
            local npc = v.Parent
            if npc.Name ~= player.Name and v.Health > 0 then
                local d = (player.Character.HumanoidRootPart.Position - npc.HumanoidRootPart.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = npc
                end
            end
        end
    end
    return closest
end

-- 6. Основной цикл работы
spawn(function()
    while wait(0.1) do
        if _G.AutoFarmNearest and player.Character then
            local target = getNearestEnemy()
            if target then
                -- Логика перемещения к NPC
                player.Character.Humanoid:MoveTo(target.HumanoidRootPart.Position)
                -- Здесь можно добавить вызов твоей функции атаки (RemoteEvent)
            end
        end
    end
end)
