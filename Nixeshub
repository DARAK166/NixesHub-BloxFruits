--- ФУНКЦИИ (БАЗА) ---

-- 1. Функция стягивания (BringMob)
local function BringMobsFunc()
    for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
        if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            if v:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (v.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if dist <= _G.Settings.Distance then
                    v.HumanoidRootPart.CanCollide = false
                    -- Телепортируем моба перед игроком
                    v.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
                    
                    -- Чтобы мобы не "разлетались" (базовая фишка открытых скриптов)
                    if v.HumanoidRootPart:FindFirstChild("BodyVelocity") then
                        v.HumanoidRootPart.BodyVelocity:Destroy()
                    end
                end
            end
        end
    end
end

-- 2. Функция выбора оружия
local function EquipWeapon()
    local tool = player.Backpack:FindFirstChild(_G.Settings.WeaponType) or player.Character:FindFirstChild(_G.Settings.WeaponType)
    
    -- Если по ToolTip (стандарт для Blox Fruits)
    if not tool then
        for _, v in pairs(player.Backpack:GetChildren()) do
            if v:IsA("Tool") and (v.ToolTip == _G.Settings.WeaponType or string.find(v.Name, _G.Settings.WeaponType)) then
                tool = v
                break
            end
        end
    end
    
    if tool and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid:EquipTool(tool)
    end
end

--- UI ЭЛЕМЕНТЫ ---

local function AddButton(parent, text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(30, 35, 45)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.Gotham
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

