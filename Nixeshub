local function CreatePage(name)
    local p = Instance.new("ScrollingFrame")
    p.Name = name
    p.Size = UDim2.new(1, 0, 1, 0)
    p.BackgroundTransparency = 1
    p.Visible = false
    p.ScrollBarThickness = 0
    p.Parent = Pages
    Instance.new("UIListLayout", p).Padding = UDim.new(0, 8)
    return p
end

