-- Цикл Автофарма (Полет + Удары)
task.spawn(function()
    while task.wait() do
        if _G.Settings.AutoFarm then
            local mob = GetNearestMonster()
            if mob and mob:FindFirstChild("HumanoidRootPart") then
                -- Летим под моба (позиция фарма)
                player.Character.HumanoidRootPart.CFrame = mob.HumanoidRootPart.CFrame * CFrame.new(0, -10, 0)
                AutoClick() -- Сами бьем
            end
        end
    end
end)

-- Цикл BringMob
task.spawn(function()
    while task.wait() do
        if _G.Settings.BringMob then
            pcall(function()
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("HumanoidRootPart") and (v.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude < _G.Settings.FarmDistance then
                        v.HumanoidRootPart.CanCollide = false
                        v.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
                    end
                end
            end)
        end
    end
end)

-- Цикл сбора яиц (через проверку Workspace)
task.spawn(function()
    while task.wait(0.5) do
        if _G.Settings.AutoEgg then
            for _, v in pairs(workspace:GetChildren()) do
                if string.find(v.Name, "Egg") and v:IsA("BasePart") then
                    TweenTo(v.CFrame)
                end
            end
        end
    end
end)

-- Авто-экипировка
task.spawn(function()
    while task.wait(1) do
        if _G.Settings.AutoFarm or _G.Settings.BringMob then
            local tool = player.Backpack:FindFirstChild(_G.Settings.WeaponType)
            if not tool then
                for _, t in pairs(player.Backpack:GetChildren()) do
                    if t.ToolTip == _G.Settings.WeaponType then tool = t break end
                end
            end
            if tool then player.Character.Humanoid:EquipTool(tool) end
        end
    end
end)
