local TabButtons = {}
local TabFrames = {}

-- Функция создания кнопок вкладок
function CreateTabButton(name, index, posOffset)
    local Button = Instance.new("TextButton")
    Button.Parent = TabsContainer
    Button.Text = name
    Button.Font = Enum.Font.GothamMedium
    Button.TextSize = 14
    Button.TextColor3 = ColorTheme.GrayText
    Button.TextScaled = false
    
    Button.BackgroundColor3 = ColorTheme.ButtonBg
    Button.BorderSizePixel = 0
    Button.Position = UDim2.new(0, posOffset, 0, 0)
    Button.Size = UDim2.new(0, 100, 1, 0)
    
    -- Подсветка активной вкладки
    local SelectionIndicator = Instance.new("Frame")
    SelectionIndicator.Name = "SelectionIndicator"
    SelectionIndicator.Parent = Button
    SelectionIndicator.BackgroundColor3 = ColorTheme.Accent
    SelectionIndicator.BorderSizePixel = 0
    SelectionIndicator.Size = UDim2.new(1, 0, 0, 2)
    SelectionIndicator.Position = UDim2.new(0, 0, 1, 0)
    SelectionIndicator.Visible = index == 1
    
    -- Контент вкладки
    local ContentFrame = Instance.new("ScrollingFrame")
    ContentFrame.Name = "Content"
    ContentFrame.Parent = MainFrame
    ContentFrame.BackgroundColor3 = ColorTheme.Glass
    ContentFrame.BorderSizePixel = 0
    ContentFrame.Position = UDim2.new(0, 0, 0, 75)
    ContentFrame.Size = UDim2.new(1, 0, 1, -75)
    ContentFrame.ScrollBarThickness = 4
    ContentFrame.ScrollBarImageColor3 = ColorTheme.Accent
    ContentFrame.CanvasSize = UDim2.new(0, 0, 0, 200)
    ContentFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    ContentFrame.Visible = index == 1
    
    -- Методы переключения
    Button.MouseButton1Click:Connect(function()
        for i, btn in pairs(TabButtons) do
            TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = ColorTheme.GrayText}):Play()
            btn.SelectionIndicator.Visible = false
            TabFrames[i].Visible = false
        end
        
        TweenService:Create(Button, TweenInfo.new(0.2), {TextColor3 = ColorTheme.Text}):Play()
        SelectionIndicator.Visible = true
        ContentFrame.Visible = true
    end)
    
    table.insert(TabButtons, Button)
    table.insert(TabFrames, ContentFrame)
    return ContentFrame
end

-- === ГЕНЕРАЦИЯ КНОПОК В ШАБЛОНЕ ===
function CreateActionButton(parent, title, subtext)
    local BtnContainer = Instance.new("Frame")
    BtnContainer.Name = title
    BtnContainer.BackgroundColor3 = ColorTheme.ButtonBg
    BtnContainer.BorderSizePixel = 0
    BtnContainer.Position = UDim2.new(0, 10, 0, #parent:GetChildren() * 45)
    BtnContainer.Size = UDim2.new(1, -20, 0, 45)
    BtnContainer.Parent = parent
    
    local BtnLabel = Instance.new("TextLabel")
    BtnLabel.Parent = BtnContainer
    BtnLabel.BackgroundTransparency = 1
    BtnLabel.Text = title
    BtnLabel.Font = Enum.Font.GothamBold
    BtnLabel.TextSize = 14
    BtnLabel.TextColor3 = ColorTheme.Text
    BtnLabel.Size = UDim2.new(0.65, 0, 1, 0)
    BtnLabel.Position = UDim2.new(0, 10, 0, 0)
    BtnLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local SubLabel = Instance.new("TextLabel")
    SubLabel.Parent = BtnContainer
    SubLabel.BackgroundTransparency = 1
    SubLabel.Text = subtext
    SubLabel.Font = Enum.Font.GothamLight
    SubLabel.TextSize = 12
    SubLabel.TextColor3 = ColorTheme.GrayText
    SubLabel.Size = UDim2.new(0.35, 0, 1, 0)
    SubLabel.Position = UDim2.new(0.65, 0, 0, 0)
    SubLabel.TextXAlignment = Enum.TextXAlignment.Right
    
    -- Имитация кнопки (безопасная)
    BtnContainer.MouseButton1Click:Connect(function()
        warn("[UI CLICK] Action: " .. title)
        -- Сюда вставляется логика (для обучения в своей игре)
    end)
end

