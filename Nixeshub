-- Glass Effect Creator
local function createGlass(parent, c, a, r)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1,0,1,0)
    frame.Position = UDim2.new(0,0,0,0)
    frame.BackgroundColor3 = c or Color3.fromRGB(20,20,35)
    frame.BackgroundTransparency = a or 0.15
    frame.BorderSizePixel = 0
    frame.Parent = parent

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, r or 12)
    corner.Parent = frame

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(80,120,255)
    stroke.Thickness = 1.2
    stroke.Transparency = 0.4
    stroke.Parent = frame

    -- Glass blur
    local blur = Instance.new("ImageLabel")
    blur.Image = "rbxassetid://5554236805"
    blur.ImageColor3 = Color3.fromRGB(30,40,70)
    blur.ImageTransparency = 0.65
    blur.ScaleType = Enum.ScaleType.Crop
    blur.Size = UDim2.new(1.2,0,1.2,0)
    blur.Position = UDim2.new(-0.1,0,-0.1,0)
    blur.BackgroundTransparency = 1
    blur.BorderSizePixel = 0
    blur.ZIndex = -1
    blur.Parent = frame
    blur.Name = "GlassNoise"

    -- Animated stroke
    spawn(function()
        while frame and frame.Parent do
            local t = tick() * 0.5
            stroke.Color = Color3.fromHSV(t % 1, 0.6, 1)
            RunService.RenderStepped:Wait()
        end
    end)

    return frame
end

