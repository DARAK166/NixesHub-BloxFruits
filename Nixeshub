-- 1. Auto Equip Logic
task.spawn(function()
    while task.wait(0.5) do
        pcall(function()
            if Settings.BringMob then -- Берем в руки только если фарм активен
                local char = player.Character
                if char and not char:FindFirstChildOfClass("Tool") then
                    for _, tool in ipairs(player.Backpack:GetChildren()) do
                        if tool:IsA("Tool") and (tool.ToolTip == Settings.WeaponType or string.find(tool.Name, Settings.WeaponType)) then
                            char.Humanoid:EquipTool(tool)
                        end
                    end
                end
            end
        end)
    end
end)

-- 2. Bring Mob Logic
task.spawn(function()
    while task.wait() do
        if Settings.BringMob then
            pcall(function()
                local char = player.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                
                local myRoot = char.HumanoidRootPart
                local enemies = workspace:FindFirstChild("Enemies") or workspace:FindFirstChild("NPCs")
                
                if enemies then
                    for _, monster in pairs(enemies:GetChildren()) do
                        if monster:FindFirstChild("Humanoid") and monster.Humanoid.Health > 0 then
                            local monsterRoot = monster:FindFirstChild("HumanoidRootPart")
                            if monsterRoot then
                                local dist = (monsterRoot.Position - myRoot.Position).Magnitude
                                if dist <= Settings.Distance then
                                    -- Стягиваем моба к себе
                                    monsterRoot.CanCollide = false
                                    monsterRoot.CFrame = myRoot.CFrame * CFrame.new(0, 0, -5)
                                end
                            end
                        end
                    end
                end
            end)
        end
    end
end)

-- Navigation
local function ShowPage(name)
    for _, p in pairs(Pages:GetChildren()) do
        if p:IsA("ScrollingFrame") then
            p.Visible = (p.Name == name)
        end
    end
end

local function CreateTab(name, pos)
    local tab = Instance.new("TextButton")
    tab.Size = UDim2.new(1, -10, 0, 30)
    tab.Position = UDim2.new(0, 5, 0, pos)
    tab.BackgroundColor3 = Color3.fromRGB(40, 50, 60)
    tab.BackgroundTransparency = 0.8
    tab.Text = name
    tab.TextColor3 = Color3.fromRGB(255, 255, 255)
    tab.Font = Enum.Font.Gotham
    tab.Parent = NavBar
    Instance.new("UICorner").Parent = tab
    tab.MouseButton1Click:Connect(function() ShowPage(name) end)
end

